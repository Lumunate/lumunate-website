<!-- Title -->
<table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:28px;">
  <tr>
    <td>
      <p style="margin:0 0 6px;font-size:11px;font-weight:600;color:#888888;letter-spacing:2px;text-transform:uppercase;">Contact Form</p>
      <h1 style="margin:0;font-size:24px;font-weight:700;color:#0d0d0d;line-height:1.3;">New Inquiry Received</h1>
    </td>
    <td align="right" valign="top">
      <span style="display:inline-block;background-color:#f0fdf4;color:#16a34a;font-size:11px;font-weight:600;padding:4px 12px;border-radius:20px;border:1px solid #bbf7d0;letter-spacing:0.5px;">SUBMITTED</span>
    </td>
  </tr>
</table>

<p style="margin:0 0 28px;font-size:14px;color:#555555;line-height:1.6;">
  A new contact form submission has come in. Review the details below and follow up at your earliest convenience.
</p>

<!-- Fields Table -->
<table width="100%" cellpadding="0" cellspacing="0" border="0" style="border:1px solid #ebebeb;border-radius:8px;overflow:hidden;">
  {{#each fields}}
  <tr style="{{#unless @last}}border-bottom:1px solid #f5f5f5;{{/unless}}">
    <td style="padding:14px 20px;width:130px;font-size:12px;font-weight:600;color:#888888;letter-spacing:0.5px;text-transform:uppercase;white-space:nowrap;vertical-align:top;background-color:#fafafa;border-right:1px solid #f0f0f0;">
      {{label}}
    </td>
    <td style="padding:14px 20px;font-size:14px;color:#1a1a1a;line-height:1.5;vertical-align:top;">
      {{value}}
    </td>
  </tr>
  {{/each}}
</table>
